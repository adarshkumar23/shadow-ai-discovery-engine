[loggers]
keys=root,uvicorn,uvicorn.access,uvicorn.error

[handlers]
keys=console

[formatters]
keys=default

[logger_root]
level=INFO
handlers=console

[logger_uvicorn]
level=INFO
handlers=console
qualname=uvicorn

[logger_uvicorn.access]
level=INFO
handlers=console
qualname=uvicorn.access

[logger_uvicorn.error]
level=INFO
handlers=console
qualname=uvicorn.error

[handler_console]
class=StreamHandler
args=(sys.stdout,)
level=INFO
formatter=default

[formatter_default]
format=%(message)s

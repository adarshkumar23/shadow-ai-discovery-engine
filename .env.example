# ── Application ────────────────────────────
APP_ENV=development          # development | staging | production
APP_VERSION=0.1.0
APP_NAME=shadow-ai-discovery
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ── Database ───────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shadow_ai

# ── Capability Flag ────────────────────────
# Set to true to enable all Shadow AI endpoints
# At integration: replaced by DB query against
# CompliVibe innovation_capabilities table
SHADOW_AI_ENABLED=true

# ── Encryption ─────────────────────────────
# Fernet key for encrypting IdP OAuth tokens at rest
# Generate: python -c "from cryptography.fernet
# import Fernet; print(Fernet.generate_key().decode())"
SHADOW_AI_FERNET_KEY=

# ── Tier 2 IdP — Okta (per-customer at runtime) ──
# These are CompliVibe's registered OAuth app credentials
# Customer-specific tokens stored encrypted in DB
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=

# ── Tier 2 IdP — Azure AD ─────────────────
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_REDIRECT_URI=http://localhost:8000/api/v1/shadow-ai/idp/callback/azure

# ── Tier 2 IdP — Google Workspace ─────────
# DO NOT commit real values — rotate before any push
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/shadow-ai/idp/callback/google

# ── Tier 3 Connector ───────────────────────
# Rate limit for connector ingest endpoint
CONNECTOR_RATE_LIMIT_PER_HOUR=1000

# ── AWS (for Tier 3 connector testing) ─────
# DO NOT commit real values — rotate before any push
AWS_CONTROL_TEST_ACCESS_KEY_ID=
AWS_CONTROL_TEST_SECRET_ACCESS_KEY=
AWS_CONTROL_TEST_REGION=ap-south-1
